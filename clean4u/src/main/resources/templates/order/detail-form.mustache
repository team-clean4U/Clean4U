{{> layout/header}}
{{> layout/background}}

<div class="detail-container order-detail">
    <div class="detail-container-content">
        <div class="buttons">
            <form action="/orders" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                {{^order.isCancelled}}
                <a href="/orders/{{order.orderId}}/update" class="btn btn-edit">
                    <i class="fa-solid fa-edit"></i> 수정
                </a>
                    {{#order.isReceived}}
                        {{#order.isPending}}
                            <button class="btn btn-cancel" onclick="cancelOrder({{order.orderId}})"><i class="fa-solid fa-xmark"></i>접수 취소</button>
                        {{/order.isPending}}
                    {{/order.isReceived}}
                {{/order.isCancelled}}

                {{#sessionUser.isAdmin}}
                    {{^order.isPaid}}
                    <button class="btn btn-delete" onclick="deleteOrder({{order.orderId}})"><i class="fa-solid fa-trash"></i>
                        <input type="hidden" name="hardDelete" value="true">
                        주문 삭제
                    </button>
                    {{/order.isPaid}}
                {{/sessionUser.isAdmin}}
                </form>
            </div>
        </div>

        <div class="detail-card">
            <div class="id-container">
                <div class="detail-id-card">NO.{{orderId}}</div>
            </div>
            <div class="detail-header order-detail-header">
                <i class="fa-solid fa-shopping-bag"></i>
                <h4>{{order.customerName}} <span class="info-label">님 주문</span></h4>
                <span class="user-info {{#order.grade}}grade-{{order.grade}}{{/order.grade}}">{{order.grade}}</span>
            </div>

            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                         <i class="fa-solid fa-calendar-check"></i>
                        주문 접수일
                    </span>
                    <span class="detail-value">{{order.orderDate}}</span>
                </div>

                <div class="detail-item">
                    <div class="detail-label status-label">
                        <span>
                             <i class="fa-solid fa-spinner"></i>
                            세탁 상태
                        </span>
                        <span class="history-items">
                            {{#history}}<span>{{createdAt}} {{status.displayName}} {{editor}}</span>{{/history}}
                        </span>
                    </div>
                    <span class="detail-value">
                        <span class="status-badge {{order.status.cssClass}}">
                            {{order.status.displayName}}
                        </span>
                    </span>

                </div>
                <div class="detail-item">
                    <span class="detail-label">
                         <i class="fa-solid fa-note-sticky"></i>
                        메모
                    </span>
                    {{#order.memo}}
                        <span class="detail-value text-line-break">{{order.memo}}</span>
                    {{/order.memo}}
                </div>
            </div>

            <div class="order-laundry-item">
                <div class="detail-item last">
                    <span class="detail-label">
                        <i class="fa-solid fa-shirt"></i>
                        세탁 물품
                    </span>
                {{#order.laundryImage}}
                    <button style="margin: 0;"
                            type="button" class="btn image-item" onclick="openImageModal('/images/{{order.laundryImage}}')">
                        <i class="fa-solid fa-image"></i>
                         <span>물품 사진 보기</span>
                    </button>
                {{/order.laundryImage}}
                </div>

                {{#items}}
                    <div class="laundry-card">

                        <div class="laundry-info-header">
                            <div>
                                <span>{{laundryItemName}}</span>
                                <span class="laundry-gray">({{laundryCategory}})</span>
                            </div>
                        </div>
                        <div class="laundry-info-detail">
                            <div class="laundry-item-row">
                                <span class="laundry-item-label">수량:</span>
                                <span class="laundry-item-value">{{quantity}}개</span>
                            </div>
                            <div class="laundry-item-row">
                                <span class="laundry-item-label">기본 가격:</span>
                                <span class="laundry-item-value">{{basePrice}}원</span>

                            </div>
                            {{#options}}
                                <div class="laundry-item-row option-row">
                                    <span class="laundry-item-label">추가 옵션:</span>
                                    <div class="option-card">
                                        <span class="option-label">옵션</span>
                                        <span class="laundry-item-value">{{optionName}}</span>
                                        <span class="laundry-item-value option-price">+ {{extraPrice}}원</span>
                                    </div>
                                </div>
                            {{/options}}
                        </div>

                        <div class="laundry-info-subtotal">
                            <span class="subtotal-label">소계</span>
                            <span class="subtotal-value">
                            {{itemTotalPrice}}원
                        </span>
                        </div>
                    </div>
                {{/items}}

                <div class="order-total">
                    <span class="detail-label">
                        <i class="fa-solid fa-won-sign"></i>
                        {{#order.isPending}}총 결제 예정 금액{{/order.isPending}}
                        {{^order.isPending}}총 결제 금액{{/order.isPending}}
                    </span>
                    <span class="order-total-value">
                        총 <span id="amount">{{order.totalPrice}}</span>원
                    </span>
                </div>
                <div style="text-align: center;">
                    <input type="hidden" id="orderId" value="{{order.orderId}}">
                        <div class="btn-payment-wrapper" id="paymentArea">
                         {{#order.isPending}}{{^order.isCancelled}}
                                <button type="button" id="paymentBtn" class="btn btn-payment">
                                    <span class="payment-emoji">
                                        <i class="fa-solid fa-credit-card"></i>
                                    </span>
                                    <span class="payment-request">결제 QR 요청하기</span>
                                </button>
                         {{/order.isCancelled}}{{/order.isPending}}
                        {{^order.isPending}}{{#payment}}
                            <div class="payment-refund-card">
                                <span style="color: var(--color-dark-blue); font-weight: 500;">
                                    [결제 완료] 주문번호: {{merchantUid}}
                                </span>
                                <a href="/refunds/{{id}}">
                                    <span class="btn btn-delete">
                                        환불 요청
                                    </span>
                                </a>
                            </div>
                        {{/payment}}{{/order.isPending}}
                        </div>
                </div>
            </div>
        </div>

        {{#order.reviewLink}}
            <div class="detail-card review-card">
                <div class="detail-header">
                    <h4>
                        <i class="fa-solid fa-star"></i>
                        리뷰
                    </h4>
                </div>

                <div class="detail-body">
                    {{#order.hasReview}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-star"></i>
                                평점
                            </span>
                            <div class="detail-value">
                                <span class="review-rating-stars">
                                    {{#order.review.rating}}
                                        {{#.}}★{{/.}}{{^.}}☆{{/.}}
                                    {{/order.review.rating}}
                                </span>
                                <span>{{order.review.rating}}점</span>
                            </div>
                        </div>
                        {{#order.review.comment}}
                            <div class="detail-item">
                                <span class="detail-label">
                                    <i class="fa-solid fa-comment"></i>
                                    리뷰 내용
                                </span>
                                <div class="detail-value review-comment">
                                    {{order.review.comment}}
                                </div>
                            </div>
                        {{/order.review.comment}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-calendar"></i>
                                작성일
                            </span>
                            <span class="detail-value">{{order.review.createdAt}}</span>
                        </div>
                    {{/order.hasReview}}
                    {{^order.hasReview}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-link"></i>
                                리뷰 작성
                            </span>
                            <div class="detail-value">
                                <form action="/orders/{{order.orderId}}/review-link/send" method="post" style="display: inline;">
                                    <button type="submit" class="btn btn-create">
                                        <i class="fa-solid fa-paper-plane"></i> 리뷰 작성 링크 전송
                                    </button>
                                </form>
                            </div>
                        </div>
                    {{/order.hasReview}}
                </div>
            </div>
        {{/order.reviewLink}}
    </div>
</div>

<div id="imageModal" class="imageModal" onclick="closeImageModal()">
    <img id="modalImage" class="modalImage" alt="세탁물품 사진">
</div>
<script src="/js/order/detail.js"></script>
<script src="/js/order/delete.js"></script>
<script src="https://cdn.iamport.kr/v1/iamport.js"></script>
<script src="/js/payment.js"></script>
<script src="/js/refund.js"></script>

{{>layout/footer}}

{{#alertMessage}}
    alert("{{alertMessage}}")
{{/alertMessage}}
