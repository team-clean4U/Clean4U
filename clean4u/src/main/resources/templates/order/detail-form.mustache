{{> layout/header}}
{{> layout/background}}

<div class="detail-container order-detail">
    <div class="detail-container-content">
        <div class="buttons">
            <form action="/order/list" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                {{^order.isCancelled}}
                <a href="/order/{{order.orderId}}/update" class="btn btn-edit">
                    <i class="fa-solid fa-edit"></i> 수정
                </a>
                <form action="/order/{{order.orderId}}/delete" method="post" onsubmit="return confirm('주문 접수를 취소하시겠습니까?')">
                    <button class="btn btn-cancel"><i class="fa-solid fa-xmark"></i>접수 취소</button>
                </form>
                {{/order.isCancelled}}
                <form action="/order/{{order.orderId}}/delete" method="post" onsubmit="return confirm('주문 내역이 완전히 삭제됩니다. 삭제하시겠습니까?')">
                {{#isAdmin}}
                    <button class="btn btn-delete"><i class="fa-solid fa-trash"></i>
                        <input type="hidden" name="hardDelete" value="true">
                        주문 삭제
                    </button>
                {{/isAdmin}}
                </form>
            </div>
        </div>

        <div class="detail-card">
            <div class="id-container">
                <div class="detail-id-card">NO.{{orderId}}</div>
            </div>
            <div class="detail-header order-detail-header">
                <i class="fa-solid fa-shopping-bag"></i>
                <h4>{{order.customerName}} <span class="info-label">님 주문</span></h4>
                <span class="user-info {{#order.grade}}grade-{{order.grade}}{{/order.grade}}">{{order.grade}}</span>
            </div>

            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                         <i class="fa-solid fa-calendar-check"></i>
                        주문 접수일
                    </span>
                    <span class="detail-value">{{order.orderDate}}</span>
                </div>

                <div class="detail-item">
                    <div class="status-label">
                        <span class="detail-label">
                             <i class="fa-solid fa-spinner"></i>
                            세탁 상태
                        </span>
                        <span class="detail-value history-items">
                            {{#history}}<span>{{createdAt}} {{status.displayName}} {{editor}}</span>{{/history}}
                        </span>
                    </div>
                    <span class="detail-value">
                        <span class="status-badge {{order.status.cssClass}}">
                            {{order.status.displayName}}
                        </span>
                    </span>

                </div>
                <div class="detail-item">
                    <span class="detail-label">
                         <i class="fa-solid fa-note-sticky"></i>
                        메모
                    </span>
                    {{#order.memo}}
                        <span class="detail-value text-line-break">{{order.memo}}</span>
                    {{/order.memo}}
                </div>
            </div>

            <div class="order-laundry-item">
                <div class="detail-item last">
                    <span class="detail-label">
                        <i class="fa-solid fa-shirt"></i>
                        세탁 물품
                    </span>
                {{#order.laundryImage}}
                    <button style="margin: 0;"
                            type="button" class="btn image-item" onclick="openImageModal('/images/{{order.laundryImage}}')">
                        <i class="fa-solid fa-image"></i>
                         <span>물품 사진 보기</span>
                    </button>
                {{/order.laundryImage}}
                </div>

                {{#items}}
                    <div class="laundry-card">

                        <div class="laundry-info-header">
                            <div>
                                <span>{{laundryItemName}}</span>
                                <span class="laundry-gray">({{laundryCategory}})</span>
                            </div>
                        </div>
                        <div class="laundry-info-detail">
                            <div class="laundry-item-row">
                                <span class="laundry-item-label">수량:</span>
                                <span class="laundry-item-value">{{quantity}}개</span>
                            </div>
                            <div class="laundry-item-row">
                                <span class="laundry-item-label">기본 가격:</span>
                                <span class="laundry-item-value">{{basePrice}}원</span>

                            </div>
                            {{#options}}
                                <div class="laundry-item-row option-row">
                                    <span class="laundry-item-label">추가 옵션:</span>
                                    <div class="option-card">
                                        <span class="option-label">옵션</span>
                                        <span class="laundry-item-value">{{optionName}}</span>
                                        <span class="laundry-item-value option-price">+ {{extraPrice}}원</span>
                                    </div>
                                </div>
                            {{/options}}
                        </div>

                        <div class="laundry-info-subtotal">
                            <span class="subtotal-label">소계</span>
                            <span class="subtotal-value">
                            {{itemTotalPrice}}원
                        </span>
                        </div>
                    </div>
                {{/items}}

                <div class="order-total">
                    <span class="detail-label">
                        <i class="fa-solid fa-won-sign"></i>
                        총 결제금액
                    </span>
                    <span class="order-total-value">
                        총 {{order.totalPrice}}원
                    </span>
                </div>
            </div>
        </div>

        {{#order.reviewLink}}
            <div class="detail-card review-card">
                <div class="detail-header">
                    <h4>
                        <i class="fa-solid fa-star"></i>
                        리뷰
                    </h4>
                </div>

                <div class="detail-body">
                    {{#order.hasReview}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-star"></i>
                                평점
                            </span>
                            <div class="detail-value">
                                <span class="review-rating-stars">
                                    {{#order.review.rating}}
                                        {{#.}}★{{/.}}{{^.}}☆{{/.}}
                                    {{/order.review.rating}}
                                </span>
                                <span>{{order.review.rating}}점</span>
                            </div>
                        </div>
                        {{#order.review.comment}}
                            <div class="detail-item">
                                <span class="detail-label">
                                    <i class="fa-solid fa-comment"></i>
                                    리뷰 내용
                                </span>
                                <div class="detail-value review-comment">
                                    {{order.review.comment}}
                                </div>
                            </div>
                        {{/order.review.comment}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-calendar"></i>
                                작성일
                            </span>
                            <span class="detail-value">{{order.review.createdAt}}</span>
                        </div>
                    {{/order.hasReview}}
                    {{^order.hasReview}}
                        <div class="detail-item">
                            <span class="detail-label">
                                <i class="fa-solid fa-link"></i>
                                리뷰 작성
                            </span>
                            <div class="detail-value">
                                <button type="button" onclick="copyReviewLink(this, '{{order.reviewLink}}')" class="btn btn-create">
                                    <i class="fa-solid fa-copy"></i> 리뷰 작성 링크 복사
                                </button>
                            </div>
                        </div>
                    {{/order.hasReview}}
                </div>
            </div>
        {{/order.reviewLink}}
    </div>
</div>

<div id="imageModal" class="imageModal" onclick="closeImageModal()">
    <img id="modalImage" class="modalImage" alt="세탁물품 사진">
</div>
<script src="/js/order-detail.js"></script>

{{>layout/footer}}

{{#alertMessage}}
    alert("{{alertMessage}}")
{{/alertMessage}}


