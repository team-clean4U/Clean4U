{{> layout/header}}

{{> layout/background}}

<div class="update-container">
    <div class="update-container-content">
        <div class="update-card">
            <form action="/order/{{order.orderId}}/update" method="post">
                <div class="detail-header">
                    <i class="fa-solid fa-user"></i>
                    <h4>{{order.customerName}}</h4>
                </div>
                <div class="update-body">
                    <div class="update-item">
                        <span class="update-label">
                            <i class="fa-solid fa-soap"></i>
                            세탁 상태
                        </span>
                        <div class="update-value category">
                            <input type="hidden" name="status" id="status" value="{{order.status}}">
                            <div class="category-select" data-selected="{{order.status}}">
                                <span class="category-selected">{{order.status.displayName}}</span>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                            <ul class="category-dropdown" data-selected="{{order.status}}">
                                <li data-id="RECEIVED" data-type="RECEIVED">접수</li>
                                <li data-id="WASHING" data-type="WASHING">세탁중</li>
                                <li data-id="DRYING" data-type="DRYING">건조중</li>
                                <li data-id="COMPLETED" data-type="COMPLETED">세탁완료</li>
                            </ul>
                        </div>
                    </div>

                    <div class="update-item">
                        <label for="memo" class="update-label">
                            <i class="fa-solid fa-hourglass"></i>
                            메모
                        </label>
                        <input type="text" id="memo" name="memo"
                               placeholder="메모를 작성해주세요" class="update-value" {{#order.memo}}value="{{order.memo}}"{{/order.memo}}>
                    </div>

                    <div id="items-container" style="padding: 24px 0; flex-direction: column; gap: 1rem;">
                        <div class="item-add">
                            <label for="items" class="update-label">
                                <i class="fa-solid fa-circle-info"></i>
                                세탁 물품
                            </label>
                            <button type="button" class="btn btn-add" onclick="addItem()">
                                + 세탁 물품 추가
                            </button>
                        </div>
                        {{#items}}
                            <div class="update-item-list" data-index="{{index}}" style="width: 100%; padding: 1.5rem 2rem; border-bottom: 1px dashed var(--color-light-gray);" >
                                <input type="hidden" name="items[{{index}}].laundryItemId" value="{{laundryItemId}}">
                                <div style="display: flex; justify-content: space-between; gap: 1rem;">
                                    <div class="update-item order-item"
                                         style="padding-top: 0; border-bottom: none; display: flex; justify-content: space-between; align-items: center; width: 90%;">
                                        <label class="update-value" style="font-weight: 500;">{{laundryItemName}}</label>
                                        <input
                                                style="width: 90px;"
                                                class="update-value"
                                                type="number"
                                                name="items[{{index}}].quantity"
                                                min="1"
                                                value="{{quantity}}">
                                    </div>
                                    <div>
                                        <button class="btn btn-delete"
                                                type="button"
                                                style="
                                                    margin-top: 6px;
                                                    height: 36px;
                                                    padding: 0 12px;
                                                    font-size: 14px;
                                                    display: flex;
                                                    align-items: center;
                                                    gap: 6px;
                                                    flex-shrink: 0;"
                                                onclick="removeItem(this)"
                                        ><i class="fa-solid fa-trash"></i>삭제</button>
                                    </div>
                                </div>

                                <div style="
                                    display: flex;
                                    flex-direction: column;
                                    gap: 0.75rem;
                                    padding: 1rem 0;
                                ">
                                    <span class="option-label" style="width: fit-content">옵션</span>
                                    <div style="
                                        display: flex;
                                        flex-wrap: wrap;
                                        gap: 0.6rem 1rem;
                                    ">
                                        {{#options}}
                                            <label style="
                                            display: flex;
                                            align-items: center;
                                            white-space: nowrap;
                                            gap: 0.3rem;
                                        ">
                                                <input
                                                        type="checkbox"
                                                        name="items[{{index}}].optionIds"
                                                        value="{{id}}"
                                                        {{#checked}}checked{{/checked}}
                                                >
                                                {{name}} (+{{extraPrice}})
                                            </label>
                                        {{/options}}
                                    </div>
                                </div>
                            </div>
                        {{/items}}
                    </div>

                </div>
                <div class="bottom-buttons">
                    <a href="/order/{{order.orderId}}" class="btn btn-back">취소</a>
                    <button type="submit" class="btn btn-create">수정 완료</button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> layout/footer}}

<script src="/js/order-update.js"></script>

<script id="laundry-items-data" type="application/json">
{{& laundryItemJson}}
</script>

<script id="laundry-options-data" type="application/json">
{{& laundryOptionsJson}}
</script>

<input type="hidden" id="itemsSize" value="{{itemsSize}}">