{{> layout/header}}

{{> layout/background}}

<div class="detail-container">
    <div class="detail-container-content">
        <div class="buttons">
            <form action="/laundry-items" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                
                {{#laundryItem.isActive}}
                <form id="deactivateForm" action="/laundry-items/{{laundryItem.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="false">
                    <button type="button" class="btn btn-deactivate" onclick="if(confirm('비활성화하시겠습니까?')) document.getElementById('deactivateForm').submit();">
                        <i class="fa-solid fa-ban"></i>비활성화
                    </button>
                </form>
                {{/laundryItem.isActive}}
                {{^laundryItem.isActive}}
                <form id="activateForm" action="/laundry-items/{{laundryItem.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="true">
                    <button type="button" class="btn btn-activate" onclick="if(confirm('활성화하시겠습니까?')) document.getElementById('activateForm').submit();">
                        <i class="fa-solid fa-check"></i>활성화
                    </button>
                </form>
                {{/laundryItem.isActive}}
                <a href="/laundry-items/{{laundryItem.id}}/edit" class="btn btn-edit">
                    <i class="fa-solid fa-edit"></i> 수정
                </a>
                <button class="btn btn-delete" onclick="deleteLaundryItem({{laundryItem.id}})"><i class="fa-solid fa-trash"></i>삭제</button>
            </div>
        </div>
        <div class="detail-card">
            <div class="detail-header">
                <i class="fa-solid fa-{{laundryItem.icon}}"></i>
                <h4>{{laundryItem.name}}</h4>
            </div>
            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-list"></i>
                        카테고리
                    </span>
                    <span class="detail-value category">
                        {{laundryItem.category}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-won-sign"></i>
                        기본 가격
                    </span>
                    <span class="detail-value price">
                        {{laundryItem.basePrice}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-circle-info"></i>
                        설명
                    </span>
                    <span class="detail-value text-line-break">{{laundryItem.description}}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-heart"></i>
                        활성 여부
                    </span>
                    <span class="detail-value {{#laundryItem.isActive}}status-active{{/laundryItem.isActive}} {{^laundryItem.isActive}}status-inactive{{/laundryItem.isActive}}">
                        {{#laundryItem.isActive}}활성{{/laundryItem.isActive}}
                        {{^laundryItem.isActive}}비활성{{/laundryItem.isActive}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-hourglass"></i>
                        생성일
                    </span>
                    <span class="detail-value">
                        {{laundryItem.createdAt}}
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}

<script src="/js/laundryItem/delete.js"></script>