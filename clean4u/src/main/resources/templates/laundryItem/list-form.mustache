{{> layout/header}}

{{> layout/background}}

<!-- http://localhost:8080/laundry-item -->
<div class="content-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">
                <i class="fa-solid fa-tshirt"></i>세탁물 목록
            </h2>
            <a href="/laundry-item/save" class="btn btn-create">
                <span>+</span>생성
            </a>
        </div>

        <div class="card-list">
            {{#laundryItemList}}
                <a href="/laundry-item/{{id}}" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-{{icon}}"></i>
                        <h4>{{name}}</h4>
                    </div>
                    <div class="card-body">
                        <div class="card-info">
                            <span class="info-label">카테고리:</span>
                            <span class="info-value">{{category}}</span>
                        </div>
                        <div class="card-info">
                            <span class="info-label">기본가격:</span>
                            <span class="info-value price">{{basePrice}}</span>
                        </div>
                    </div>
                </a>
            {{/laundryItemList}}
        </div>
        {{^laundryItemList}}
            <p class="blank">등록된 세탁물이 없습니다.</p>
        {{/laundryItemList}}
    </div>
</div>

{{> layout/footer}}