

{{> layout/header}}

<div class="detail-container">
    <div class="detail-container-content">
        <div class="buttons">
            <form action="/override/list" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                <form action="/override/{{override.id}}/delete" method="post">
                    <button class="btn btn-delete"><i class="fa-solid fa-trash"></i>삭제</button>
                </form>
            </div>
        </div>

        <div class="detail-card">
            <div class="detail-header">
                <i class="fa-solid fa-calendar-check"></i>
                <h4>병결/대체 근무 상세</h4>
            </div>

            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-user"></i>
                        원래 근무자
                    </span>
                    <span class="detail-value">{{override.originalName}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-user-check"></i>
                        대체 근무자
                    </span>
                    <span class="detail-value">{{override.overrideName}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-calendar-days"></i>
                        날짜
                    </span>
                    <span class="detail-value">{{override.date}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-clock"></i>
                        시작 시간
                    </span>
                    <span class="detail-value">{{override.startTime}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-clock"></i>
                        종료 시간
                    </span>
                    <span class="detail-value">{{override.endTime}}</span>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}