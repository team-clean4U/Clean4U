{{> layout/header}}
{{> layout/background}}

<div class="content-section employee-search-section">
    <div class="container employee-search-container">
        <div class="header-container">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="fa-solid fa-user-check"></i>
                    직원 검색
                </h2>
            </div>

            <!-- 검색 폼 -->
            <form action="/schedules/employees" method="get" class="search-wrapper">
                <div class="search-input-box">
                    <i class="fa-solid fa-search"></i>
                    <input type="text"
                           name="keyword"
                           value="{{keyword}}"
                           placeholder="직원 이름 입력"
                           class="search-input"
                           autocomplete="off"/>
                </div>
                <button type="submit" class="btn btn-submit">검색</button>
            </form>
        </div>

        <!-- 검색 결과 -->
        <div class="employee-search-list">
            {{#employeeList}}
                <div class="employee-search-content">
                    <div class="employee-search-info">
                        <div class="employee-search-icon">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <div class="employee-search-name">
                            {{name}}
                            <span class="employee-search-username">아이디: {{username}}</span>
                        </div>
                    </div>
                    <a href="/schedules/{{id}}/new" class="btn employee-btn">
                        선택
                    </a>
                </div>
            {{/employeeList}}

            {{^employeeList}}
                <p>검색 결과가 없습니다.</p>
            {{/employeeList}}
        </div>
    </div>
</div>

{{> layout/footer}}