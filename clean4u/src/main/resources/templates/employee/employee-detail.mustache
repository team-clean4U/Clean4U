{{> layout/header}}

<div class="detail-container">
    <div class="detail-container-content">

        <div class="buttons">
            <a href="/employee/list" class="btn btn-back">
                <i class="fas fa-arrow-left"></i> 목록으로
            </a>

            <form action="/employee/{{detail.id}}/delete" method="post">
                <button type="submit" class="btn btn-delete">
                    <i class="fas fa-trash"></i> 삭제
                </button>
            </form>
        </div>

        <div class="detail-card">
            <div class="detail-header">
                <i class="fas fa-user"></i>
                {{detail.name}}
            </div>

            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fas fa-id-badge"></i> 아이디
                    </span>
                    <span class="detail-value">{{detail.username}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fas fa-envelope"></i> 이메일
                    </span>
                    <span class="detail-value">{{detail.email}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fas fa-user-shield"></i> 권한
                    </span>
                    <span class="detail-value">{{detail.userRole}}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fas fa-toggle-on"></i> 상태
                    </span>
                    <span class="detail-value status-{{detail.userStatus}}">
                        {{detail.userStatus}}
                    </span>
                </div>
            </div>
        </div>

    </div>
</div>

{{> layout/footer}}