<!DOCTYPE html>
<html lang="en">

<head>
    <title>Clean4U</title>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <link rel="stylesheet"
          href="https://site-assets.fontawesome.com/releases/v7.0.0/css/all.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/dropdown.css">
    <link rel="stylesheet" href="/css/stock-notice.css">
    <link rel="stylesheet" href="/css/list.css">
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-lite.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js" integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-lite.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/lang/summernote-ko-KR.min.js"></script>

    {{#additionalCss}}
        <link rel="stylesheet" href="{{.}}">
    {{/additionalCss}}
</head>

<body>
<nav class="navbar">
    <div class="navbar-container">
        <div class="nav-left">
            <a class="navbar-brand" href="/main">
                <i class="fa-solid fa-soap"></i> Clean4U
            </a>
            {{#sessionUser}}
                <div class="stock-notice-dropdown">
                    <button class="stock-notice-bell" id="lowStockBell">
                        <i class="fa-solid fa-bell"></i>
                        {{#lowStockCount}}
                            <span class="stock-notice-badge">{{lowStockCount}}</span>
                        {{/lowStockCount}}
                    </button>
                    <div class="stock-notice-dropdown-menu" id="lowStockDropdown" style="display: none;">
                        <div class="stock-notice-header">
                            <h4>재고 부족 알림</h4>
                        </div>
                        <div class="stock-notice-list">
                            {{#lowStockItems}}
                                <a href="/supply-item/{{id}}" class="stock-notice-item">
                                    <div class="stock-notice-item-content">
                                        <i class="fa-solid fa-triangle-exclamation"></i>
                                        <div>
                                            <b>{{name}}</b>
                                            <span class="stock-notice-item-detail">
                                            현재: {{stockQuantity}}{{unit}} / 안전재고: {{safetyStock}}{{unit}}
                                        </span>
                                        </div>
                                    </div>
                                </a>
                            {{/lowStockItems}}
                            {{^lowStockItems}}
                                <div class="stock-notice-empty">재고 부족 항목이 없습니다.</div>
                            {{/lowStockItems}}
                        </div>
                    </div>
                </div>
            {{/sessionUser}}
        </div>
        <input type="checkbox" id="navbar-toggle" class="navbar-toggle-checkbox">
        <label for="navbar-toggle" class="navbar-toggle">
            <i class="fa-solid fa-bars"></i>
        </label>
        <label for="navbar-toggle" class="navbar-overlay"></label>
        <div class="navbar-menu">
            <label for="navbar-toggle" class="navbar-close">
                <i class="fa-solid fa-times"></i>
            </label>
            <ul class="navbar-nav">
                {{#sessionUser}}
                    {{#sessionUser.isAdmin}}
                        <li class="nav-item dropdown dropdown-admin">
                            <input type="checkbox" id="dropdown-admin" class="dropdown-checkbox">
                            <label for="dropdown-admin" class="nav-link dropdown-toggle">
                                <i class="fa-solid fa-shield-halved"></i> 관리자
                                <i class="fa-solid fa-chevron-down"></i>
                            </label>
                            <ul class="dropdown-menu">
                                <li>
                                    <a href="/employee/list" class="dropdown-item">
                                        <i class="fa-solid fa-users"></i>
                                        직원 관리
                                    </a>
                                </li>
                                <li>
                                    <a href="/employee/join-list" class="dropdown-item">
                                        <i class="fa-solid fa-user-clock"></i>
                                        승인 대기 리스트
                                    </a>
                                </li>
                                <li>
                                    <a href="/schedule/list" class="dropdown-item">
                                        <i class="fa-solid fa-calendar-days"></i>
                                        근무 일정 관리
                                    </a>
                                </li>
                                <li>
                                    <a href="/override/list" class="dropdown-item">
                                        <i class="fa-solid fa-arrows-rotate"></i>
                                        교체 근무 관리
                                    </a>
                                </li>
                            </ul>
                        </li>
                    {{/sessionUser.isAdmin}}
                    <li class="nav-item">
                        <a class="nav-link" href="/main">
                            <i class="fa-solid fa-home"></i> 대시보드
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <input type="checkbox" id="dropdown-business" class="dropdown-checkbox">
                        <label for="dropdown-business" class="nav-link dropdown-toggle">
                            <i class="fa-solid fa-briefcase"></i>업무 관리
                            <i class="fa-solid fa-chevron-down"></i>
                        </label>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="/customers/list">
                                    <i class="fa-solid fa-user-group"></i>고객 관리
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/orders">
                                    <i class="fa-solid fa-cart-shopping"></i>주문 관리
                                </a>
                            </li>
                            <li>
                                <a href="/order-status-histories" class="dropdown-item">
                                    <i class="fa-solid fa-chart-line"></i>상태 변경 이력
                                </a>
                            </li>
                            <li>
                                <a href="/payments" class="dropdown-item">
                                    <i class="fa-solid fa-credit-card"></i>결제/환불 조회
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/notices/list">
                                    <i class="fa-solid fa-bullhorn"></i>공지사항
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown dropdown-management">
                        <input type="checkbox" id="dropdown-management" class="dropdown-checkbox">
                        <label for="dropdown-management" class="nav-link dropdown-toggle">
                            <i class="fa-solid fa-list"></i>자료 관리
                            <i class="fa-solid fa-chevron-down"></i>
                        </label>
                        <ul class="dropdown-menu">
                            <li>
                                <a href="/laundry-items/list" class="dropdown-item">
                                    <i class="fa-solid fa-shirt"></i>
                                    세탁물 관리
                                </a>
                            </li>
                            <li>
                                <a href="/laundry-options/list" class="dropdown-item">
                                    <i class="fa-solid fa-tags"></i>
                                    세탁 옵션 관리
                                </a>
                            </li>
                            <li>
                                <a href="/supply-items/list" class="dropdown-item">
                                    <i class="fa-solid fa-box"></i>
                                    비품 관리
                                </a>
                            </li>
                            <li>
                                <a href="/supply-item-histories/list" class="dropdown-item">
                                    <i class="fa-solid fa-chart-line"></i>
                                    비품 입/출고 이력
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item nav-item-profile">
                        <a class="nav-link" href="/me/update">
                            <i class="fa-solid fa-user"></i> 내 정보 수정
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/logout">
                            <i class="fa-solid fa-right-from-bracket"></i> 로그아웃
                        </a>
                    </li>
                {{/sessionUser}}

                {{^sessionUser}}
                    <li class="nav-item">
                        <a class="nav-link" href="/join">
                            <i class="fa-solid fa-user"></i> 회원가입
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/login">
                            <i class="fa-solid fa-right-to-bracket"></i> 로그인
                        </a>
                    </li>
                {{/sessionUser}}

            </ul>
        </div>
    </div>
</nav>