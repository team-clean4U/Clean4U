{{> layout/header}}
{{> layout/background}}
<div class="detail-container" style="display: flex; flex-direction: column; padding: 4rem 25rem;">
    <div class="buttons">
        <form action="/orders" method="get">
            <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
        </form>
    </div>
    <div class="detail-card">
        <div class="detail-header">
            <h4>환불 요청 내역</h4>
        </div>
        <form id="refundData" data-payment-id="{{payment.id}}">
        {{#payment}}
                <div class="detail-body">
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-key"></i>Imp Uid
                        </label>
                        <span class="detail-value">{{impUid}}</span>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-hashtag"></i>주문번호
                        </label>
                        <span class="detail-value">{{merchantUid}}</span>

                    </div>
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-credit-card"></i>결제가격
                        </label>
                        <span class="detail-value">{{amount}}원</span>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-calendar-check"></i>결제일시
                        </label>
                        <span class="detail-value">{{paidAt}}</span>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-circle-info"></i>결제상태
                        </label>
                        <span class="status-badge {{status.cssClass}}">{{status.displayName}}</span>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">
                            <i class="fa-solid fa-file-lines"></i>환불 사유
                        </label>
                        <textarea name="reason" id="reason" rows="3" placeholder="환불 사유를 입력하세요" class="refund-text" required></textarea>

                    </div>
                </div>
            <div>
                <div class="bottom-buttons" style="justify-content: center; padding: 0 2.5rem 2rem;">
                    <button class="btn btn-cancel" type="submit" style="text-align: center; cursor: pointer;" >환불 요청</button>
                </div>
            </div>
        {{/payment}}
        </form>
    </div>
</div>
<script src="js/refund/refund.js"></script>
{{>layout/footer}}