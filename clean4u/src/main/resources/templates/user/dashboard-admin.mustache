<!-- http://localhost:8080/admin/dashboard -->

{{> layout/header}}

{{> layout/background}}

<div class="container">
    <div class="section-header admin-header">

        <div class="admin-header-left">
            <h2 class="section-title">
                <i class="fa-solid fa-home"></i>
                관리자 대시보드
            </h2>

            <a href="/employees?status=pending" class="btn btn-delete">
                <i class="fa-solid fa-user-clock"></i>
                <span>{{pendingCount}}명 <b>승인 대기</b></span>
            </a>
        </div>

        <a href="/employees/me" class="btn btn-edit">
            <i class="fa-solid fa-user"></i>
            내 정보 수정
        </a>
    </div>


    <div class="dashboard-list">
        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-users"></i>
                    직원 관리
                </h3>
            </div>
            <div class="card-list-two">
                <a href="/employees" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-users"></i>
                        <h4>직원 수</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">전체 직원</span>
                        <span class="info-value">{{countAllEmployees}} 명</span>
                    </div>
                </a>
                <a href="/overrides" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-arrows-rotate"></i>
                        <h4>대체 근무</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 교체</span>
                        <span class="info-value">{{countTodayOverrides}} 건</span>
                    </div>
                </a>
            </div>
        </div>

        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-clipboard-list"></i>
                    주문 관리
                </h3>
            </div>

            <div class="card-list">
                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-cart-plus"></i>
                        <h4>오늘 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 주문 건수</span>
                        <span class="info-value">{{todayOrders}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 매출</span>
                        <span class="info-value">{{todaySales}} 원</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-hourglass-half"></i>
                        <h4>처리 중 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">현재 진행</span>
                        <span class="info-value">{{processingOrders}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="status-badge {{washing.cssClass}}">세탁중</span>
                        <span class="info-value">{{washingOrders}} 건</span>
                        <span class="status-badge {{drying.cssClass}}">건조중</span>
                        <span class="info-value">{{dryingOrders}} 건</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-circle-check"></i>
                        <h4>완료된 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 완료 건수</span>
                        <span class="info-value">{{completedOrders}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">평균 처리 경과 시간</span>
                        <span class="info-value">{{averageTime}}</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-list-two">
            <div class="dashboard-group">
                <div class="group-title">
                    <h3>
                        <i class="fa-solid fa-shirt"></i>
                        인기 세탁 카테고리
                    </h3>
                </div>
                <a href="/laundry-items" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-{{mostOrderedCategoryIcon}}"></i>
                        <h4>{{mostOrderedCategory}}</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">주문 건수</span>
                        <span class="info-value">{{mostOrderedCategoryCount}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">매출액</span>
                        <span class="info-value">{{mostOrderedCategoryTotalPrice}} 원</span>
                    </div>
                </a>
            </div>

            <div class="dashboard-group">
                <div class="group-title">
                    <h3>
                        <i class="fa-solid fa-tag"></i>
                        인기 세탁 옵션
                    </h3>
                </div>
                <a href="/laundry-options" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-tag"></i>
                        <h4>{{mostOrderedOptionName}}</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">주문 건수</span>
                        <span class="info-value">{{mostOrderedOptionCount}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">매출액</span>
                        <span class="info-value">{{mostOrderedOptionTotalPrice}} 원</span>
                    </div>
                </a>
            </div>
        </div>

        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-chart-pie"></i>
                    세탁 옵션 통계
                </h3>
            </div>
            <div class="chart-container">
                <canvas id="myChart"></canvas>
            </div>
        </div>

        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-bell"></i>
                    매장 알림
                </h3>
            </div>
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-box-open"></i>
                    <h4>재고 알림</h4>
                </div>
                <div class="low-stock-list">
                    {{#lowStockItems}}
                        <a href="/supply-items/{{id}}" class="low-stock-card">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <p>
                                재고 부족: <b>{{name}}</b> ({{stockQuantity}}{{unit}} 남음 / 안전재고 : {{safetyStock}}{{unit}})
                            </p>
                        </a>
                    {{/lowStockItems}}
                    {{^lowStockItems}}
                        <div>
                            <i class="fa-solid fa-check-circle"></i>
                            <p>재고 부족 항목이 없습니다.</p>
                        </div>
                    {{/lowStockItems}}
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    fetch("/admin/option-chart")
            .then(res => res.json())
            .then(optionChart => {
                const labels = optionChart.map(o => o[0]);
                const dataValue = optionChart.map(o => o[1]);

                const data = {
                    labels: labels, // 조각 이름
                    datasets: [{
                        label: '주문 수',
                        data: dataValue,
                        backgroundColor: [
                            'rgba(79, 195, 247, 0.85)',
                            'rgba(129, 212, 250, 0.85)',
                            'rgba(77, 208, 225, 0.85)',
                            'rgba(144, 202, 249, 0.85)',
                            'rgba(100, 181, 246, 0.85)'
                        ],
                        borderColor: [
                            'rgba(79, 195, 247, 1)',
                            'rgba(98, 189, 248, 1)',
                            'rgba(77, 208, 225, 1)',
                            'rgba(122, 192, 248, 1)',
                            'rgba(100, 181, 246, 1)'
                        ],
                        borderWidth: 2,
                        hoverOffset: 8,
                        hoverBorderWidth: 3
                    }]
                };

                const config = {
                    type: 'pie',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        aspectRatio: 1.5,
                        layout: {
                            padding: {
                                top: 20,
                                bottom: 20,
                                left: 20,
                                right: 100
                            }
                        },
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    padding: 18,
                                    boxWidth: 30,
                                    boxHeight: 15,
                                    boxPadding: 10,
                                    font: {
                                        size: 13,
                                        weight: '500'
                                    },
                                    color: '#1A237E'
                                }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(255, 255, 255, 0.95)',
                                padding: 12,
                                boxPadding: 10,
                                titleFont: {
                                    size: 14,
                                    weight: '600'
                                },
                                bodyFont: {
                                    size: 13
                                },
                                titleColor: '#1A237E',
                                bodyColor: '#1A237E',
                                borderColor: 'rgba(79, 195, 247, 0.3)',
                                borderWidth: 1,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        return context.label + ': ' + context.parsed + '건';
                                    }
                                }
                            }
                        }
                    }
                };
                new Chart(document.getElementById('myChart'), config);
            });
</script>

{{> layout/footer}}