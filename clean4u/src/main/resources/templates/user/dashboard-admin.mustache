<!-- http://localhost:8080/admin/dashboard -->

{{> layout/header}}

<div class="container">
    <div class="section-header admin-header">

        <div class="admin-header-left">
            <h2 class="section-title">
                <i class="fa-solid fa-home"></i>
                관리자 대시보드
            </h2>

            <a href="/employee/join-list" class="btn btn-delete">
                <i class="fa-solid fa-user-clock"></i>
                <span>{{pendingCount}}명 승인 대기</span>
            </a>
        </div>

        <a href="/employee/me/edit" class="btn btn-edit">
            <i class="fa-solid fa-user"></i>
            내 정보 수정
        </a>
    </div>


    <div class="dashboard-list">
        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-users"></i>
                    직원 관리
                </h3>
            </div>
            <div class="card-list">
                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-users"></i>
                        <h4>직원 수</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">전체 직원</span>
                        <span class="info-value">{{! employeeCount }} 명</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-calendar-check"></i>
                        <h4>오늘 근무</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">근무 인원</span>
                        <span class="info-value">{{! todayWorkingCount }} 명</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-arrows-rotate"></i>
                        <h4>대체 근무</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 교체</span>
                        <span class="info-value">{{! overrideCount }} 건</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-clipboard-list"></i>
                    주문 관리
                </h3>
            </div>

            <div class="card-list">
                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-cart-plus"></i>
                        <h4>오늘 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">신규 주문</span>
                        <span class="info-value">{{! todayOrders }} 건</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-hourglass-half"></i>
                        <h4>진행 중 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">처리 중</span>
                        <span class="info-value">{{! processingOrders }} 건</span>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-circle-check"></i>
                        <h4>완료된 주문</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">오늘 완료</span>
                        <span class="info-value">{{! completedOrders }} 건</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-list-two">
            <div class="dashboard-group">
                <div class="group-title">
                    <h3>
                        <i class="fa-solid fa-shirt"></i>
                        인기 세탁 카테고리
                    </h3>
                </div>
                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-{{mostOrderedCategoryIcon}}"></i>
                        <h4>{{mostOrderedCategory}}</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">주문 건수</span>
                        <span class="info-value">{{mostOrderedCategoryCount}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">매출액</span>
                        <span class="info-value">{{mostOrderedCategoryTotalPrice}} 원</span>
                    </div>
                </div>
            </div>

            <div class="dashboard-group">
                <div class="group-title">
                    <h3>
                        <i class="fa-solid fa-tag"></i>
                        인기 세탁 옵션
                    </h3>
                </div>
                <div class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-tag"></i>
                        <h4>{{mostOrderedOptionName}}</h4>
                    </div>
                    <div class="card-info">
                        <span class="info-label">주문 건수</span>
                        <span class="info-value">{{mostOrderedOptionCount}} 건</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label">매출액</span>
                        <span class="info-value">{{mostOrderedOptionTotalPrice}} 원</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-group">
            <div class="group-title">
                <h3>
                    <i class="fa-solid fa-bell"></i>
                    매장 알림
                </h3>
            </div>
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-box-open"></i>
                    <h4>재고 알림</h4>
                </div>
                <div class="low-stock-list">
                    {{#lowStockItems}}
                        <div class="low-stock-card">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <p>
                                재고 부족: <b>{{name}}</b> ({{stockQuantity}}{{unit}} 남음 / 안전재고 : {{safetyStock}}{{unit}})
                            </p>
                        </div>
                    {{/lowStockItems}}
                    {{^lowStockItems}}
                        <div>
                            <i class="fa-solid fa-check-circle"></i>
                            <p>재고 부족 항목이 없습니다.</p>
                        </div>
                    {{/lowStockItems}}
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}