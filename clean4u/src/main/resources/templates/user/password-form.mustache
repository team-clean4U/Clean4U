{{> layout/header}}

{{> layout/background}}

<div class="login-container">
    <div class="login-card">
        <div class="detail-header">
            <i class="fa-solid fa-user-plus"></i>
            <h2 class="login-title">비밀번호 찾기</h2>
        </div>

        <div class="detail-body">
            {{#msg}}
                <div class="status-badge status-inactive" style="margin-bottom: 1rem;">
                    {{msg}}
                </div>
            {{/msg}}

            <form action="/password" method="post" class="user-form">
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-user"></i> 아이디
                    </div>
                    <input type="text" name="username" placeholder="아이디 입력" required>
                </div>

                <!-- 이메일 -->
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-envelope"></i> 이메일
                    </div>
                    <div class="email-group">
                        <input type="email" id="email" name="email" placeholder="이메일 입력" required>
                    </div>
                </div>

                <div class="login-footer">
                    <button type="submit" class="btn btn-create">
                        <span>+</span> 메일 전송
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> layout/footer}}