{{> layout/header}}

{{> layout/background}}

<div class="login-container">
    <div class="login-card">
        <div class="detail-header">
            <i class="fa-solid fa-user-plus"></i>
            <h2 class="login-title">직원 등록</h2>
        </div>

        <div class="detail-body">
            {{#msg}}
                <div class="status-badge status-inactive" style="margin-bottom: 1rem;">
                    {{msg}}
                </div>
            {{/msg}}

            <form action="/employees/new" method="post" class="user-form">
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-id-badge"></i> 이름
                    </div>
                    <input type="text" name="name" placeholder="이름 입력" required>
                </div>

                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-user"></i> 아이디
                    </div>
                    <input type="text" name="username" placeholder="아이디 입력" required>
                </div>

                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-lock"></i> 비밀번호
                    </div>
                    <input type="password" name="password" placeholder="8자 이상" required>
                </div>

                <!-- 이메일 -->
                <div class="detail-item">
                    <div class="detail-label">
                        <i class="fa-solid fa-envelope"></i> 이메일
                    </div>
                    <div class="email-group">
                        <input type="email" id="email" name="email" placeholder="이메일 입력" required>
                        <button type="button" class="btn btn-send" onclick="callSendApi()">
                            <i class="fa-solid fa-envelope"></i> 인증번호 전송
                        </button>
                    </div>
                </div>

                <!-- 인증번호 -->
                <div class="detail-item" id="code-box" style="display: none;">
                    <div class="detail-label">
                        <i class="fa-solid fa-key"></i> 인증번호
                    </div>
                    <div class="input-group">
                        <input type="text" id="code" placeholder="6자리 입력" maxlength="6">
                        <div class="verify-div">
                            <button type="button" class="btn btn-verify" onclick="callVerifyApi()" id="verifyBtn">
                                확인
                            </button>
                        </div>
                    </div>
                    <div id="msg"></div>
                </div>

                <!-- 인증 여부 -->
                <input type="hidden" id="isEmailVerified" name="isEmailVerified" value="false">

                <div class="join-footer">
                    <button type="submit" class="btn btn-create">
                        <i class="fa-solid fa-plus btn-create-icon"></i> 등록하기
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> layout/footer}}
<script src="/js/employee/join.js"></script>