{{> layout/header}}

{{> layout/background}}

<div class="detail-container">
    <div class="detail-container-content supply-item">
        <div class="buttons">
            <form action="/supply-items" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                <a href="/supply-items/{{supplyItem.id}}/edit" class="btn btn-edit">
                    <i class="fa-solid fa-edit"></i> 수정
                </a>
                {{#supplyItem.isActive}}
                <form id="deactivateForm" action="/supply-items/{{supplyItem.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="false">
                    <button type="button" class="btn btn-delete" onclick="if(confirm('비활성화하시겠습니까?')) document.getElementById('deactivateForm').submit();">
                        <i class="fa-solid fa-ban"></i>비활성화
                    </button>
                </form>
                {{/supplyItem.isActive}}
                {{^supplyItem.isActive}}
                <form id="activateForm" action="/supply-items/{{supplyItem.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="true">
                    <button type="button" class="btn btn-activate" onclick="if(confirm('활성화하시겠습니까?')) document.getElementById('activateForm').submit();">
                        <i class="fa-solid fa-check"></i>활성화
                    </button>
                </form>
                {{/supplyItem.isActive}}
            </div>
        </div>
        <div class="detail-card">
            <div class="detail-header">
                <i class="fa-solid fa-spray-can"></i>
                <h4>{{supplyItem.name}}</h4>
            </div>
            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-boxes"></i>
                        재고 수량
                    </span>
                    <span class="detail-value stock-quantity">
                        {{supplyItem.stockQuantity}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-scale-balanced"></i>
                        단위
                    </span>
                    <span class="detail-value">
                        {{supplyItem.unit}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-shield-halved"></i>
                        안전 재고
                    </span>
                    <span class="detail-value safety-stock">
                        {{supplyItem.safetyStock}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        {{#supplyItem.isLowStock}}
                            <i class="fa-solid fa-triangle-exclamation"></i>{{/supplyItem.isLowStock}}
                        {{^supplyItem.isLowStock}}<i class="fa-solid fa-circle-check"></i>{{/supplyItem.isLowStock}}
                        재고 상태
                    </span>
                    <span class="detail-value stock-badge {{#supplyItem.isLowStock}}badge-warn{{/supplyItem.isLowStock}} {{^supplyItem.isLowStock}}badge-safe{{/supplyItem.isLowStock}}">
                        {{#supplyItem.isLowStock}}주의{{/supplyItem.isLowStock}}
                        {{^supplyItem.isLowStock}}안전{{/supplyItem.isLowStock}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-heart"></i>
                        활성 여부
                    </span>
                    <span class="detail-value {{#supplyItem.isActive}}status-active{{/supplyItem.isActive}} {{^supplyItem.isActive}}status-inactive{{/supplyItem.isActive}}">
                        {{#supplyItem.isActive}}활성{{/supplyItem.isActive}}
                        {{^supplyItem.isActive}}비활성{{/supplyItem.isActive}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-hourglass"></i>
                        생성일
                    </span>
                    <span class="detail-value">
                        {{supplyItem.createdAt}}
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}