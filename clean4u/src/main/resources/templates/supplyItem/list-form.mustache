{{> layout/header}}

{{> layout/background}}

<!-- http://localhost:8080/supply-item -->
<!-- http://localhost:8080/login -->
<div class="content-section">
    <div class="container">
        <div class="header-container">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="fa-solid fa-box"></i>자재 목록
                </h2>
                <a href="/supply-item/save" class="btn btn-create">
                    <span>+</span>생성
                </a>
            </div>
            <form class="search-wrapper" method="get" action="/supply-item">
                <div class="search-input-box">
                    <i class="fa-solid fa-search"></i>
                    <input class="search-input" type="text" placeholder="검색어를 입력해주세요." value="{{name}}" name="name">
                </div>
                <div class="update-value category">
                    <input type="hidden" name="lowStock" id="category" {{#lowStock}}value="{{lowStock}}" {{/lowStock}}>
                    <div class="category-select" {{#lowStock}}data-selected="{{lowStock}}" {{/lowStock}}>
                        <i class="fa-solid fa-list"></i>
                        <span class="category-selected">
                        {{#lowStockTrue}}주의{{/lowStockTrue}}
                            {{#lowStockFalse}}안전{{/lowStockFalse}}
                            {{^lowStockTrue}}{{^lowStockFalse}}전체{{/lowStockFalse}}{{/lowStockTrue}}
                        </span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                    <ul class="category-dropdown">
                        <li data-type="">전체</li>
                        <li data-type="false">안전</li>
                        <li data-type="true">주의</li>
                    </ul>
                </div>
                <button type="submit" class="btn btn-submit">조회</button>
            </form>
        </div>

        <div class="card-list">
            {{#supplyItemList}}
                <a href="/supply-item/{{id}}" class="card">
                    <div class="card-header">
                        <i class="fa-solid fa-spray-can"></i>
                        <h4>{{name}}</h4>
                    </div>
                    <div class="card-body">
                        <div class="card-info">
                            <span class="info-label">재고 수량:</span>
                            <span class="info-value">{{stockQuantity}}</span>
                        </div>
                        <div class="card-info">
                            <span class="info-label">단위:</span>
                            <span class="info-value">{{unit}}</span>
                        </div>
                    </div>
                </a>
            {{/supplyItemList}}
        </div>
        {{^supplyItemList}}
            <p class="blank">등록된 자재가 없습니다.</p>
        {{/supplyItemList}}
    </div>
</div>

{{> layout/footer}}