{{> layout/header}}

{{> layout/background}}

<!-- http://localhost:8080/laundry-option/save -->
<div class="update-container">
    <div class="update-container-content">
        <div class="update-card">
            <form action="/laundry-options/new" method="post">
                <div class="update-header">
                    <i class="fa-solid fa-tag"></i>
                    <input type="text" name="name" placeholder="세탁물 옵션을 입력해주세요." required>
                </div>
                <div class="update-body">
                    <div class="update-item">
                        <label for="extraPrice" class="update-label">
                            <i class="fa-solid fa-won-sign"></i>
                            추가 요금
                        </label>
                        <input type="number" id="extraPrice" name="extraPrice" min="0" step="1000"
                               placeholder="추가 요금을 입력해주세요." class="update-value price">
                    </div>
                    <div class="update-item">
                        <label for="description" class="update-label">
                            <i class="fa-solid fa-circle-info"></i>
                            설명
                        </label>
                        <textarea id="description" name="description" placeholder="설명을 입력해주세요." rows="5"
                                  class="update-value"></textarea>
                    </div>
                    <div class="update-item">
                        <label class="update-label">
                            <i class="fa-solid fa-heart"></i>
                            활성 여부
                        </label>
                        <label class="toggle-switch">
                            <input type="checkbox" id="isActive" name="isActive" value="true" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
                <div class="bottom-buttons">
                    <a href="/laundry-options" class="btn btn-back">취소</a>
                    <button type="submit" class="btn btn-create">완료</button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> layout/footer}}