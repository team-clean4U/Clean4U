{{> layout/header}}

<div class="container p-5">
    <div class="card">
        <div class="card-body">
            <form action="/laundry-option/save" method="post">
                <div class="mb-3">
                    <input type="text" class="form-control" placeholder="Enter name" name="name">
                </div>
                <div class="mb-3">
                    <input type="number" class="form-control" name="extraPrice" placeholder="Enter extraPrice" step="500" min="0">
                </div>
                <button class="btn btn-primary form-control">완료</button>
            </form>
        </div>
    </div>
</div>

{{> layout/footer}}