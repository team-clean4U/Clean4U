{{> layout/header}}

<div class="container p-5">

    <div class="card">
        <div class="card-header"><b>세탁물 수정 화면입니다.</b></div>
        <div class="card-body">

            <form action="/laundry-option/{{laundryOption.id}}/update" method="post">
                <div class="mb-3">
                    <input type="text" class="form-control" name="name" value="{{laundryOption.name}}">
                </div>
                <div class="mb-3">
                    <input type="number" class="form-control" name="extraPrice" value="{{laundryOption.extraPrice}}"
                           step="500">
                </div>

                <button class="btn btn-primary form-control">수정 완료</button>
            </form>

        </div>
    </div>
</div>

{{> layout/footer}}