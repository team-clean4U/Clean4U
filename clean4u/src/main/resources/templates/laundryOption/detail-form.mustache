{{> layout/header}}

{{> layout/background}}

<div class="detail-container">
    <div class="detail-container-content">
        <div class="buttons">
            <form action="/laundry-options" method="get">
                <button class="btn btn-back"><i class="fa-solid fa-arrow-left"></i>목록으로</button>
            </form>
            <div class="button-right">
                <a href="/laundry-options/{{laundryOption.id}}/edit" class="btn btn-edit">
                    <i class="fa-solid fa-edit"></i> 수정
                </a>
                {{#laundryOption.isActive}}
                <form id="deactivateForm" action="/laundry-options/{{laundryOption.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="false">
                    <button type="button" class="btn btn-delete" onclick="if(confirm('비활성화하시겠습니까?')) document.getElementById('deactivateForm').submit();">
                        <i class="fa-solid fa-ban"></i>비활성화
                    </button>
                </form>
                {{/laundryOption.isActive}}
                {{^laundryOption.isActive}}
                <form id="activateForm" action="/laundry-options/{{laundryOption.id}}/status" method="post" style="display: inline;">
                    <input type="hidden" name="isActive" value="true">
                    <button type="button" class="btn btn-activate" onclick="if(confirm('활성화하시겠습니까?')) document.getElementById('activateForm').submit();">
                        <i class="fa-solid fa-check"></i>활성화
                    </button>
                </form>
                {{/laundryOption.isActive}}
            </div>
        </div>
        <div class="detail-card">
            <div class="detail-header">
                <i class="fa-solid fa-tag"></i>
                <h4>{{laundryOption.name}}</h4>
            </div>
            <div class="detail-body">
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-won-sign"></i>
                        추가 요금
                    </span>
                    <span class="detail-value price">
                        {{laundryOption.extraPrice}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-circle-info"></i>
                        설명
                    </span>
                    <span class="detail-value text-line-break">{{laundryOption.description}}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-heart"></i>
                        활성 여부
                    </span>
                    <span class="detail-value {{#laundryOption.isActive}}status-active{{/laundryOption.isActive}} {{^laundryOption.isActive}}status-inactive{{/laundryOption.isActive}}">
                        {{#laundryOption.isActive}}활성{{/laundryOption.isActive}}
                        {{^laundryOption.isActive}}비활성{{/laundryOption.isActive}}
                    </span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">
                        <i class="fa-solid fa-hourglass"></i>
                        생성일
                    </span>
                    <span class="detail-value">
                        {{laundryOption.createdAt}}
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}